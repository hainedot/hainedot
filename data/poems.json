{
  "poems": [
    {
      "title": "つづら折り",
      "datetime": "2026-07-15",
      "displayDate": "二〇二六年七月十五日",
      "image": "1000001322.jpg",
      "lines": [
        "幸せだったあの頃を",
        "忘れられる日はいつだろう",
        "足元にはふと 星があった",
        "願いが叶うなら もう一度"
      ]
    },
    {
      "title": "日記に書かない幸せ",
      "datetime": "2026-07-16",
      "displayDate": "二〇二六年七月十六日",
      "image": "kcChsKmqQSm9_tLXySawfw.jpg",
      "lines": [
        "君の思想が好きだった",
        "いざ、対面してみると、それはずっと",
        "思い通りにいかなかった",
        "思い通りにいかないことに",
        "意味などずっと、あったと思う"
      ]
    }
  ]
}
